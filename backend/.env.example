SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,certify.uz,www.certify.uz

# ─── Database ──────────────────────────────────────────────────────────────────
DB_NAME=certify_db
DB_USER=certify_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT ───────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_LIFETIME=60
REFRESH_TOKEN_LIFETIME=7

# ─── Email ─────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=info@certify.uz
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Certify.uz <info@certify.uz>

# ─── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=https://certify.uz

# ─── Payme ─────────────────────────────────────────────────────────────────────
# https://merchant.paycom.uz — Merchant kabinetida oling
PAYME_MERCHANT_ID=your-payme-merchant-id
PAYME_SECRET_KEY=your-payme-secret-key
# Test uchun: https://test.paycom.uz  Prod uchun: https://checkout.paycom.uz
PAYME_CHECKOUT_URL=https://checkout.paycom.uz

# ─── Click ─────────────────────────────────────────────────────────────────────
# https://my.click.uz/services/ — Click biznes kabinetida oling
CLICK_SERVICE_ID=your-click-service-id
CLICK_MERCHANT_ID=your-click-merchant-id
CLICK_SECRET_KEY=your-click-secret-key
CLICK_MERCHANT_USER_ID=your-click-merchant-user-id

# ─── Eskiz SMS ─────────────────────────────────────────────────────────────────
# https://eskiz.uz — Ro'yxatdan o'ting va API kalitlarini oling
ESKIZ_EMAIL=your-eskiz-email@example.com
ESKIZ_PASSWORD=your-eskiz-password
ESKIZ_SENDER=4546

# ─── Telegram Bot ──────────────────────────────────────────────────────────────
# @BotFather orqali yangi bot yarating
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxyz
# Admin kanal yoki guruh ID (forward qilib /getid botdan oling)
TELEGRAM_ADMIN_CHAT_ID=-1001234567890

# ─── Stripe (xalqaro kartalar) ─────────────────────────────────────────────────
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Media/Static ──────────────────────────────────────────────────────────────
MEDIA_ROOT=/app/media
STATIC_ROOT=/app/staticfiles
